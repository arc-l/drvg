#Qt5
FIND_PACKAGE(Qt5 QUIET COMPONENTS Core Widgets OpenGL)
IF(Qt5_FOUND)
    MESSAGE(STATUS "Found Qt5 @ ${Qt5_INCLUDE_DIRS}")
    INCLUDE_DIRECTORIES(${Qt5_INCLUDE_DIRS})
    LIST(APPEND ALL_LIBRARIES Qt5::Core Qt5::Widgets Qt5::OpenGL)
ELSE(Qt5_FOUND)
    MESSAGE(SEND_ERROR "Cannot find Qt5!")
ENDIF(Qt5_FOUND)

#CGAL
FIND_PACKAGE(CGAL QUIET COMPONENTS Core Qt5)
IF(CGAL_FOUND)
    INCLUDE_DIRECTORIES(${CGAL_INCLUDE_DIRS})
    MESSAGE(STATUS "Found CGAL @ ${CGAL_INCLUDE_DIRS}")
    SET(CMAKE_AUTOUIC_SEARCH_PATHS ${CGAL_INCLUDE_DIRS}/CGAL/Qt/resources)
    SET(CMAKE_AUTOUIC ON)
    SET(CMAKE_AUTOMOC ON)
    INCLUDE_DIRECTORIES(${CMAKE_BINARY_DIR}) # If the .h file is generated in the binary directory
    SET(CMAKE_INCLUDE_CURRENT_DIR ON)
    MESSAGE(STATUS "CGAL_DIR: ${CGAL_DIR}")
    LIST(APPEND ALL_LIBRARIES ${CGAL_LIBRARY} CGAL::CGAL_Basic_viewer)
ELSE(CGAL_FOUND)
    MESSAGE(WARNING "Cannot find CGAL, 3D meshing not supported!")
ENDIF(CGAL_FOUND)

IF (DEFINED OMPL_ENABLE)
    MESSAGE(STATUS "OMPL Comparison: ${OMPL_ENABLE}")
    IF (${OMPL_ENABLE} STREQUAL "ON")
    FIND_PACKAGE(ompl)
    IF(OMPL_FOUND)
        INCLUDE_DIRECTORIES(${OMPL_INCLUDE_DIRS})
        MESSAGE(STATUS "Found OMPL @ ${OMPL_INCLUDE_DIRS}")
        LIST(APPEND ALL_LIBRARIES ${OMPL_LIBRARIES})
    ELSE(OMPL_FOUND)
        MESSAGE(WARNING "Cannot find OMPL, RRT* not supported!")
    ENDIF(OMPL_FOUND)
    ENDIF()
ENDIF()

